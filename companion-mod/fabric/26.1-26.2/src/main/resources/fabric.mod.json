{
	"schemaVersion": 1,
	"id": "vermeil",
	"version": "${version}",
	"name": "Vermeil",
	"description": "Companion mod for the Vermeil launcher. First feature: renders the launcher's local custom capes in-game.",
	"authors": [
		"Vermeil"
	],
	"contact": {
		"homepage": "https://github.com/Vermeil-Launcher/Vermeil-Launcher",
		"sources": "https://github.com/Vermeil-Launcher/Vermeil-Launcher"
	},
	"license": "MIT",
	"icon": "assets/vermeil/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.vermeil.VermeilMod"
		],
		"client": [
			"com.vermeil.client.VermeilModClient"
		]
	},
	"mixins": [
		{
			"config": "vermeil.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "${minecraft_depends}",
		"java": ">=${java_version}"
	}
}
